{
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      ".cursor/**",
      ".figma-ref/**"
    ],
    "redirects": [
      {
        "source": "/Index.html",
        "destination": "/",
        "type": 301
      },
      {
        "source": "/index.html",
        "destination": "/",
        "type": 301
      }
    ],
    "rewrites": [
      {
        "source": "/",
        "destination": "/Index.html"
      },
      {
        "source": "/admin/login",
        "destination": "/admin/login/index.html"
      },
      {
        "source": "/admin",
        "destination": "/admin/index.html"
      }
    ]
  }
}
