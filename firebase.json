{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      ".cursor/**",
      ".figma-ref/**"
    ],
    "redirects": [
      {
        "source": "/Index.html",
        "destination": "/",
        "type": 301
      },
      {
        "source": "/index.html",
        "destination": "/",
        "type": 301
      }
    ],
    "rewrites": [
      {
        "source": "/",
        "destination": "/Index.html"
      }
    ]
  }
}
